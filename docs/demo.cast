[19.061384, "o", "CREATE TABLE default.access_local\r\n(\r\n    `org` LowCardinality(String) COMMENT '组织',\r\n    `id` String COMMENT '请求ID',\r\n    `ts` DateTime('Asia/Shanghai') COMMENT '时间(秒)',\r\n    `ts_ms` Int64 COMMENT '时间(毫秒)',\r\n    `dt` Date DEFAULT toDate(ts) COMMENT '日期',\r\n    `req` String CODEC(ZSTD(1)) TTL ts + toIntervalDay(30),\r\n    `res` String CODEC(ZSTD(1)) TTL ts + toIntervalDay(30),\r\n    `ip` String COMMENT '客户端IP',\r\n"]

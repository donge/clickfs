[2.002422, "o", "Mount ClickHouse as a filesystem\r\n\r\n\u001b[1m\u001b[4mUsage:\u001b[0m \u001b[1mclickfs\u001b[0m <COMMAND>\r\n\r\n\u001b[1m\u001b[4mCommands:\u001b[0m\r\n  \u001b[1mmount\u001b[0m   Mount a ClickHouse server at the given mountpoint\r\n  \u001b[1mumount\u001b[0m  Unmount a previously mounted clickfs\r\n  \u001b[1mhelp\u001b[0m    Print this message or the help of the given subcommand(s)\r\n\r\n\u001b[1m\u001b[4mOptions:\u001b[0m\r\n  \u001b[1m-h\u001b[0m, \u001b[1m--help\u001b[0m     Print help\r\n  \u001b[1m-V\u001b[0m, \u001b[1m--version\u001b[0m  Print version\r\n"]
